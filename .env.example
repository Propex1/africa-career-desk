# Set to "true" in Vercel preview environments to show a preview banner.
# Leave unset or set to "false" in production.
NEXT_PUBLIC_SHOW_DEMO_NOTICE=false

# PostHog Cloud EU analytics.
# Get the project API key from PostHog → Settings → Project.
# Analytics is disabled automatically when the key is not set, so the site
# keeps working without these vars (e.g. in local dev).
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
